{
  "name": "fabd-tournament-planner",
  "version": "3.57.0",
  "description": "Planejador de Torneios - Federacao Alagoana de Badminton",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "author": "FABD - Federacao Alagoana de Badminton",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "build": {
    "appId": "com.fabd.tournament-planner",
    "productName": "FABD Tournament Planner",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "config.local.json",
        "to": "config.local.json"
      },
      {
        "from": "config.example.json",
        "to": "config.example.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/assets/icon.ico",
      "uninstallerIcon": "src/assets/icon.ico",
      "installerHeaderIcon": "src/assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FABD Tournament Planner"
    },
    "publish": null
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "ws": "^8.20.0"
  }
}
